Bootstrap: docker
From: rockylinux:9

# Your local NAMD runtime 
%files
    /path/to/NAMD_3.0.2_Linux-x86_64-verbs-smp-CUDA /opt/namd

%post
    dnf -y install \
        libstdc++ \
        libgcc \
        glibc \
        which \
        findutils \
        tar \
        gzip \
        rdma-core \
        libibverbs \
        libibumad \
        librdmacm \
        numactl-libs

    dnf clean all

    mkdir -p /work
    chmod -R 755 /opt/namd
    chmod 755 /work

%environment
    export NAMD_HOME=/opt/namd
    export PATH=/opt/namd:$PATH
    export LD_LIBRARY_PATH=/opt/namd/lib:$LD_LIBRARY_PATH
    export LC_ALL=C

%runscript
    exec /opt/namd/namd3 "$@"

%labels
    Author MSc Thesis Project
    Application NAMD-3.0.2-CUDA-SingleNode
